{
  "name": "qc-portal",
  "private": true,
  "version": "0.6.5",
  "type": "module",
  "bin": {
    "qc-portal": "bin/qc-portal.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/haonguyenstech/qc-portal.git"
  },
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm -w server run dev",
    "dev:web": "npm -w web run dev",
    "build": "npm -w web run build && npm -w server run build",
    "typecheck": "npm -w web run typecheck && npm -w server run typecheck",
    "start": "node bin/qc-portal.mjs",
    "stop": "node bin/qc-portal.mjs --stop"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
